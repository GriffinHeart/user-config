# This is Git's per-user configuration file.
[user]
  name = Hugo Almeida
  email = hugofalmeida@gmail.com
[includeIf "gitdir:~/src/work/"]
  path =  ~/.config/git/work_config
[core]
  excludesfile = ~/.config/git/.gitignore_global
  pager = delta

[delta]
  navigate = true
  dark = true
  line-numbers = true
  minus-style                   = syntax "#52313f"
  minus-non-emph-style          = syntax "#52313f"
  minus-emph-style              = syntax "#763842"
  minus-empty-line-marker-style = syntax "#52313f"
  line-numbers-minus-style      = "#914c54"
  plus-style                    = syntax "#2b485a"
  plus-non-emph-style           = syntax "#2b485a"
  plus-emph-style               = syntax "#316172"
  plus-empty-line-marker-style  = syntax "#2b485a"
  line-numbers-plus-style       = "#449dab"
  line-numbers-zero-style       = "white"
[push]
	default = current
	autoSetupRemote = true
[pull]
  ff = only
  rebase = true
[rebase]
  autostash = true
  autosquash = true
  updateRefs = true
[merge]
  tool = kdiff3
[mergetool "kdiff3"]
  trustExitCode = false
[diff]
  tool = difftastic
  guitool = kdiff3
  external = difft
[difftool]
  prompt = false
[difftool "difftastic"]
  cmd = difft "$LOCAL" "$REMOTE"
[pager]
  difftool = true
[alias]
  co = checkout
  pushf = push --force-with-lease
  p = pull --autostash
  s = stash
  sp = stash pop
  su = !git stash show -p | git apply -R
  sa = stash apply
  am = commit --amend --no-edit
  rc = rebase --continue
  ra = rebase --abort
  rs = rebase --skip
  rbd = rebase -i develop
  rbm = rebase -i main
  r = rebase -i main
  mt = mergetool
  find = log -p -S
  diffw = diff --word-diff
  # list-squashed: list local branches that were squash-merged into target branch (default: main)
	list-squashed = "!f() { local targetBranch=${1:-main} && git checkout -q $targetBranch && git branch --merged | grep -v \"\\*\"; git for-each-ref refs/heads/ \"--format=%(refname:short)\" | while read branch; do mergeBase=$(git merge-base $targetBranch $branch) && [[ $(git cherry $targetBranch $(git commit-tree $(git rev-parse $branch^{tree}) -p $mergeBase -m _)) == \"-\"* ]] && echo $branch; done; }; f"
  # delete-squashed: remove local branches that were squash-merged into target branch (default: main)
	delete-squashed = "!f() { local targetBranch=${1:-main} && git checkout -q $targetBranch && git branch --merged | grep -v \"\\*\" | xargs -n 1 git branch -d && git for-each-ref refs/heads/ \"--format=%(refname:short)\" | while read branch; do mergeBase=$(git merge-base $targetBranch $branch) && [[ $(git cherry $targetBranch $(git commit-tree $(git rev-parse $branch^{tree}) -p $mergeBase -m _)) == \"-\"* ]] && git branch -D $branch; done; }; f"
  # delete-gone: remove local branches whose remote tracking branch has been deleted
  delete-gone = "!git fetch -p && git branch -vv | grep ': gone]' | awk '{print $1}' | xargs git branch -d"
  recent = for-each-ref --sort=committerdate refs/heads/ --format='%(HEAD) %(color:yellow)%(refname:short)%(color:reset) - %(color:red)%(objectname:short)%(color:reset) - %(contents:subject) - %(authorname) (%(color:green)%(committerdate:relative)%(color:reset))'
[credential]
  helper = osxkeychain
[init]
  defaultBranch = main
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[blame]
  date = relative
[rerere]
  enabled = true
[column]
  ui = auto
[branch]
  sort = -committerdate
[fetch]
  prune = true
[commit]
  verbose = true
